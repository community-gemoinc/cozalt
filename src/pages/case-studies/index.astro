---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import InnerHero from '@components/sections/InnerHero.astro';
import { Image } from 'astro:assets';
import Date from '@components/ui/Date.astro';

export const prerender = true;

const seoTitle = "Case Studies | Cozalt";
const seoDescription = "Explore how Cozalt has helped defense and critical minerals companies achieve their strategic goals.";

// Get all case studies
const allCaseStudies = await getCollection('caseStudies');

// Filter and sort
const caseStudies = allCaseStudies
    .filter((study) => import.meta.env.DEV || study.data.publish !== false)
    .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const heroContent = {
    title: "Case Studies",
    description: "Real results for defense and critical minerals companies",
    overlayOpacity: 0.4
}
---

<Layout title={seoTitle} description={seoDescription}>
    <main>
        <InnerHero content={heroContent} />

        <section class="py-base bg-background-base">
            <div class="site-container px-4">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    {caseStudies.map((study, index) => (
                        <a
                            href={`/case-studies/${study.id}`}
                            class="group block bg-background-light rounded-lg border border-black/10 overflow-hidden hover:shadow-lg transition-shadow"
                            data-aos="fade-up"
                            data-aos-delay={index * 100}
                        >
                            {study.data.featuredImage && (
                                <div class="aspect-video overflow-hidden">
                                    <Image
                                        src={study.data.featuredImage}
                                        alt={study.data.title}
                                        width={600}
                                        height={340}
                                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                                    />
                                </div>
                            )}
                            <div class="p-6">
                                <div class="flex items-center gap-2 text-sm text-body-base/70 mb-2">
                                    <span class="px-2 py-1 bg-primary/10 text-primary rounded text-xs font-medium">
                                        {study.data.industry}
                                    </span>
                                    <Date date={study.data.publishDate} />
                                </div>
                                <h3 class="text-xl font-semibold text-headline-base mb-2 group-hover:text-primary transition-colors">
                                    {study.data.title}
                                </h3>
                                <p class="text-body-base/80 mb-4">
                                    {study.data.excerpt}
                                </p>
                                <div class="flex flex-wrap gap-4">
                                    {study.data.results.slice(0, 2).map((result) => (
                                        <div class="text-center">
                                            <div class="text-lg font-bold text-primary">{result.value}</div>
                                            <div class="text-xs text-body-base/60">{result.metric}</div>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        </a>
                    ))}
                </div>

                {caseStudies.length === 0 && (
                    <div class="text-center py-12">
                        <p class="text-body-base/70">No case studies available yet. Check back soon!</p>
                    </div>
                )}
            </div>
        </section>
    </main>
</Layout>
