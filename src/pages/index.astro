---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/sections/Hero.astro';
import SplitPanel from '@components/sections/SplitPanel.astro';
import Features from '@components/sections/Features.astro';
import { featureLists } from '@data/features';
import CtaBanner from '@components/sections/CtaBanner.astro';
import Faqs from '@components/sections/Faqs.astro';
import { faqLists } from '@data/faqs';
import Testimonials from '@components/sections/Testimonials.astro';
import { testimonialLists } from '@data/testimonials';
import Newsletter from '@components/sections/Newsletter.astro';
import heroImage from '../assets/images/home/default-hero-2.jpg';
import visionImage from '../assets/images/home/developer.jpg';

const seoTitle = "Expert Consulting in Defense and Critical Minerals | Cozalt";
const seoDescription = "Cozalt provides due diligence, business development and advisory services in the defense and critical minerals space.";

const heroContent = {
    title: 'Expert Consulting in Defense and Critical Minerals',
    description: 'Cozalt provides due diligence, business development and advisory services in the defense and critical minerals space. We empower companies to reach their full potential through strategic insights.',
    buttons: [
        {
            text: 'Book a Consultation',
            link: '/contact',
            target: '_self'
        },
        {
            text: 'View Case Studies',
            link: '/case-studies',
            target: '_self',
            variant: 'ghostLight' as const
        }
    ],
    backgroundImage: heroImage,
    overlayOpacity: 0.5
}

const aboutSection = {
    eyebrow: "About Cozalt",
    headline: "Strategic Insights for Defense & Critical Minerals",
    description: "Cozalt is a specialized consulting firm focused on the defense and critical minerals sectors. We bring deep industry expertise, proprietary research methods, and an extensive network to help our clients navigate complex markets and achieve their strategic objectives.",
    image: {
        src: visionImage,
        alt: "Cozalt consulting"
    },
    buttons: [
        {
            text: "Learn More",
            link: "/profile",
            variant: "primary" as const
        }
    ]
}

const visionSection = {
    eyebrow: "Our Vision",
    title: "Empowering Defense & Critical Minerals Businesses",
    description: "At Cozalt, we envision a world where defense and critical minerals businesses thrive through strategic insights. Our consulting services are designed to empower companies to reach their full potential and navigate the complexities of these vital industries.",
}

const servicesSection = {
    eyebrow: "Our Services",
    title: "Comprehensive Consulting Solutions",
    description: "We offer a full range of consulting services tailored to the unique needs of defense contractors, critical minerals companies, and investors in these sectors.",
    features: featureLists.main.features,
    button: {
        text: "Contact Us",
        link: "/contact",
        variant: "primary" as const
    }
}

const testimonialsSection = {
    eyebrow: "Testimonials",
    title: "What Our Clients Say",
    description: "Discover how we've helped defense and critical minerals companies achieve their goals.",
    testimonials: testimonialLists.main.testimonials
}

const faqsSection = {
    eyebrow: "FAQs",
    title: 'Frequently Asked Questions',
    description: 'Find answers to common questions about our consulting services.',
    faqs: faqLists.main.faqs
}

const newsletterSection = {
    eyebrow: "Stay Informed",
    title: "Subscribe to Our Newsletter",
    description: "Get the latest insights on defense and critical minerals markets delivered to your inbox.",
    placeholder: "Enter your email address",
    buttonText: "Subscribe",
    disclaimer: "We respect your privacy. Unsubscribe at any time."
}

const FooterCta = {
    eyebrow: "Ready to Get Started?",
    title: 'Let\'s Discuss Your Strategic Needs',
    description: 'Whether you need due diligence support, business development services, or strategic advisory, Cozalt is here to help you succeed.',
    hideCta: false,
    button: {
        text: 'Contact Us',
        link: '/contact',
        target: '_self'
    }
}
---

<Layout footerCta={FooterCta} title={seoTitle} description={seoDescription}>
    <Hero content={heroContent} />
    <SplitPanel content={aboutSection} imagePosition="right" background="light" padding="base" />
    <CtaBanner content={visionSection} variant="full-width" background="dark" padding="base" />
    <Features content={servicesSection} padding="base" background="light" />
    <Testimonials content={testimonialsSection} background="base" padding="base" />
    <Faqs content={faqsSection} background="light" padding="base" />
    <Newsletter content={newsletterSection} background="dark" padding="base" />
</Layout>
