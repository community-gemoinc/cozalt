---
import { getBackgroundColor, getTextColor, getPaddingClass, getHeadlineColor, getInputBackgroundColor, getInputTextColor } from '@utils/styleUtils';
import type { ThemeColor, PaddingSize } from '@utils/styleUtils';
import Button from '@components/ui/Button.astro';
import Eyebrow from '@components/ui/Eyebrow.astro';

export interface Props {
    content: {
        eyebrow?: string;
        title: string;
        description?: string;
        placeholder?: string;
        buttonText?: string;
        disclaimer?: string;
    };
    background?: ThemeColor;
    padding?: PaddingSize;
    paddingTop?: PaddingSize;
    paddingBottom?: PaddingSize;
}

const {
    content: {
        eyebrow,
        title,
        description,
        placeholder = 'Enter your email',
        buttonText = 'Subscribe',
        disclaimer
    },
    background = 'dark',
    padding,
    paddingTop,
    paddingBottom
} = Astro.props;

const bgColor = getBackgroundColor(background);
const textColor = getTextColor(background);
const headlineColor = getHeadlineColor(background);
const paddingClass = getPaddingClass({ padding, paddingTop, paddingBottom });
const inputBgClass = getInputBackgroundColor(background);
const inputTextClass = getInputTextColor(background);
const GOOGLE_SHEETS_URL = "https://script.google.com/macros/s/AKfycby5CQrR51LAMOkebTvnX5kRIzUymOhUYEha1GNiO6if_67chFuZ9uTHywy2az28HkUY/exec";
---

<section class:list={[bgColor, paddingClass]}>
    <div class="site-container px-4">
        <div class="max-w-2xl mx-auto text-center">
            {eyebrow && (
                <Eyebrow
                    text={eyebrow}
                    background={background}
                />
            )}

            <h2
                class:list={[headlineColor]}
                data-aos="fade-up"
            >
                {title}
            </h2>

            {description && (
                <p
                    class:list={["mt-4", textColor, "opacity-90"]}
                    data-aos="fade-up"
                    data-aos-delay="100"
                >
                    {description}
                </p>
            )}

            <div id="newsletter-message" class="hidden mt-4 p-4 rounded-lg"></div>

            <form
                id="newsletter-form"
                class="mt-8 flex flex-col sm:flex-row gap-4 justify-center"
                data-aos="fade-up"
                data-aos-delay="200"
            >
                <input
                    type="email"
                    name="email"
                    id="newsletter-email"
                    placeholder={placeholder}
                    required
                    class:list={[
                        "w-full sm:w-80 px-4 py-3",
                        inputBgClass,
                        inputTextClass,
                        "border border-primary/20",
                        "rounded-lg",
                        "focus:ring-2 focus:ring-primary focus:border-primary",
                        "placeholder:text-body-base/50"
                    ]}
                />
                <Button
                    type="submit"
                    variant="primary"
                    size="md"
                >
                    {buttonText}
                </Button>
            </form>

            {disclaimer && (
                <p
                    class:list={["mt-4 text-sm", textColor, "opacity-70"]}
                    data-aos="fade-up"
                    data-aos-delay="300"
                >
                    {disclaimer}
                </p>
            )}
        </div>
    </div>
</section>

<script define:vars={{ GOOGLE_SHEETS_URL }}>
    const newsletterForm = document.getElementById('newsletter-form');
    const newsletterMessage = document.getElementById('newsletter-message');

    newsletterForm.addEventListener('submit', async (e) => {
        e.preventDefault();

        const email = document.getElementById('newsletter-email').value;
        const data = {
            formType: 'Newsletter Subscription',
            email: email
        };

        // Show loading state
        const submitButton = newsletterForm.querySelector('button[type="submit"]');
        const originalText = submitButton.textContent;
        submitButton.textContent = 'Subscribing...';
        submitButton.disabled = true;

        try {
            const response = await fetch(GOOGLE_SHEETS_URL, {
                method: 'POST',
                mode: 'no-cors',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(data)
            });

            // Show success message
            newsletterMessage.textContent = '🎉 Success! You\'re subscribed. Check your email for your 10% discount code!';
            newsletterMessage.className = 'mt-4 p-4 rounded-lg bg-green-100 text-green-800 border border-green-300';
            newsletterMessage.classList.remove('hidden');

            // Reset form
            newsletterForm.reset();

            // Hide message after 7 seconds
            setTimeout(() => {
                newsletterMessage.classList.add('hidden');
            }, 7000);

        } catch (error) {
            // Show error message
            newsletterMessage.textContent = 'Oops! Something went wrong. Please try again.';
            newsletterMessage.className = 'mt-4 p-4 rounded-lg bg-red-100 text-red-800 border border-red-300';
            newsletterMessage.classList.remove('hidden');

            console.error('Newsletter subscription error:', error);
        } finally {
            // Reset button
            submitButton.textContent = originalText;
            submitButton.disabled = false;
        }
    });
</script>
